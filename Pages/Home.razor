@page "/"
@using QRCoder
@using System.Drawing
@using System.IO
@implements IDisposable

<PageTitle>North End Coffee - Check In</PageTitle>

<div class="check-in-container">
    <header class="header-section">
        <div class="clock-container">
            <div class="digital-clock">
                <div class="time-display">@currentTime</div>
                <div class="date-display">@currentDate</div>
            </div>
        </div>
        <div class="logo-container">
            <img src="north-end-logo.png" 
                 alt="North End Coffee" 
                 class="logo" />
        </div>
        <div class="welcome-section">
            <h1 class="branch-title">@branchName</h1>
            <p class="welcome-text">Welcome! Please check in below</p>
        </div>
    </header>
    
    <main class="main-content">
        <div class="qr-section">
            <h2 class="scan-title">Scan to Check In</h2>
            <div class="qr-wrapper">
                <img src="@qrCodeDataUri" alt="Check-in QR Code" class="qr-code" />
            </div>
        </div>
    </main>
    
    <footer class="footer-section">
        <p class="footer-text">Need help? Please contact your supervisor</p>
    </footer>
</div>

@code {
    private string qrCodeDataUri = string.Empty;
    private string branchName = "Gulshan Branch"; // Change this to your branch name
    private string currentTime = "";
    private string currentDate = "";
    private Timer? timer;

    protected override void OnInitialized()
    {
        // Generate QR code for check-in URL
        string checkInUrl = "https://www.northendcoffee.com/checkin"; // Replace with actual check-in URL
        
        using (var qrGenerator = new QRCodeGenerator())
        {
            var qrCodeData = qrGenerator.CreateQrCode(checkInUrl, QRCodeGenerator.ECCLevel.Q);
            var qrCode = new PngByteQRCode(qrCodeData);
            var qrCodeBytes = qrCode.GetGraphic(20);
            qrCodeDataUri = $"data:image/png;base64,{Convert.ToBase64String(qrCodeBytes)}";
        }
        
        // Initialize clock
        UpdateClock();
        timer = new Timer(async _ => 
        {
            UpdateClock();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.Zero, TimeSpan.FromSeconds(1));
    }
    
    private void UpdateClock()
    {
        var now = DateTime.Now;
        currentTime = now.ToString("HH:mm:ss");
        currentDate = now.ToString("dddd, MMMM dd, yyyy");
    }
    
    public void Dispose()
    {
        timer?.Dispose();
    }
}
