@page "/"
@page "/{BranchId:int}"
@using QRCoder
@using System.Drawing
@using System.IO
@using NorthEndOneEntrance.Services
@inject IEmployeeCheckInService CheckInService
@inject ISecurityService SecurityService
@inject IBranchService BranchService
@inject AppStateService AppState
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>North End Coffee - Check In</PageTitle>

@if (!AppState.IsAuthenticated)
{
    <!-- PIN Entry Screen - Alternative Professional Layout -->
    <div class="auth-screen-v2">
        <div class="auth-left-panel">
            <div class="auth-branding">
                <img src="north-end-logo.png" alt="North End Coffee" class="auth-logo-v2" />
                <h1 class="auth-welcome">Welcome</h1>
                <p class="auth-tagline">North End Coffee Entrance System</p>
                <div class="auth-divider"></div>
                <div class="auth-time">@DateTime.Now.ToString("h:mm tt")</div>
                <div class="auth-date">@DateTime.Now.ToString("MMMM dd, yyyy")</div>
            </div>
        </div>
        
        <div class="auth-right-panel">
            <div class="auth-form-container">
                <div class="auth-header">
                    <h2 class="auth-form-title">Security Verification</h2>
                    <p class="auth-form-subtitle">Please enter your 4-digit PIN</p>
                </div>
                
                <div class="pin-indicator-container">
                    @for (int i = 0; i < 4; i++)
                    {
                        <div class="pin-dot @(i < securityPin.Length ? "filled" : "")"></div>
                    }
                </div>

                <div class="keypad-grid">
                    @for (int row = 0; row < 3; row++)
                    {
                        @for (int col = 0; col < 3; col++)
                        {
                            int num = row * 3 + col + 1;
                            <button class="num-key" @onclick="() => AddPinDigit(num.ToString())">
                                <span class="num-key-value">@num</span>
                            </button>
                        }
                    }
                    <button class="num-key empty-key" disabled></button>
                    <button class="num-key" @onclick='() => AddPinDigit("0")'>
                        <span class="num-key-value">0</span>
                    </button>
                    <button class="num-key delete-key" @onclick="ClearPin">
                        <svg class="delete-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M21 4H8l-7 8 7 8h13a2 2 0 002-2V6a2 2 0 00-2-2z"/>
                            <line x1="18" y1="9" x2="12" y2="15"/>
                            <line x1="12" y1="9" x2="18" y2="15"/>
                        </svg>
                    </button>
                </div>

                <button class="auth-submit-btn" @onclick="ValidatePin" disabled="@(securityPin.Length < 4)">
                    <span>Continue</span>
                    <svg class="submit-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="5" y1="12" x2="19" y2="12"/>
                        <polyline points="12 5 19 12 12 19"/>
                    </svg>
                </button>

                @if (!string.IsNullOrEmpty(pinError))
                {
                    <div class="auth-error-message">
                        <svg class="error-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"/>
                            <line x1="12" y1="8" x2="12" y2="12"/>
                            <line x1="12" y1="16" x2="12.01" y2="16"/>
                        </svg>
                        <span>@pinError</span>
                    </div>
                }
            </div>
        </div>
    </div>
}
else if (AppState.SelectedBranch == null)
{
    <!-- Branch Selection Screen -->
    <div class="branch-selection-screen">
        <div class="branch-container">
            <img src="north-end-logo.png" alt="North End Coffee" class="auth-logo" />
            <h1 class="auth-title">Select Branch Location</h1>
            <p class="auth-subtitle">Choose your cafe branch</p>

            @if (branches == null)
            {
                <div class="loading">Loading branches...</div>
            }
            else
            {
                <div class="branch-grid">
                    @foreach (var branch in branches)
                    {
                        <button class="branch-card" @onclick="() => SelectBranch(branch)">
                            <div class="branch-name">@branch.Name</div>
                            <div class="branch-location">@branch.Location</div>
                            <div class="branch-code">@branch.Code</div>
                        </button>
                    }
                </div>
            }
        </div>
    </div>
}
else
{
    <!-- Check-In System (Existing) -->
<div class="check-in-container">
    <!-- Logout Button -->
    <button class="logout-btn" @onclick="LogoutAsync" title="Change Branch or Logout">
        ⚙️ Settings
    </button>
    
    <!-- Two-column layout: Logo on left, Check-in on right -->
    <div class="main-layout">
        <!-- Left Column: Logo and Branding -->
        <div class="left-column">
            <div class="logo-section">
                <img src="north-end-logo.png" alt="North End Coffee" class="logo" />
                <h1 class="branch-title">@branchName</h1>
                <div class="digital-clock">@currentTime</div>
                
                <!-- QR Code for Mobile Check-In -->
                <div class="qr-section">
                    <div class="qr-label">Quick Mobile Entrance</div>
                    <div class="qr-code-box">
                        <img src="@qrCodeDataUri" alt="Check-in QR Code" class="qr-code-img" />
                    </div>
                </div>
            </div>
        </div>

        <!-- Vertical Divider -->
        <div class="divider-vertical"></div>

        <!-- Right Column: Check-in Area -->
        <div class="right-column">
            @if (currentStep == CheckInStep.EnterID)
            {
                <!-- Step 1: Enter Employee ID -->
                <div class="step-container">
                    <h2 class="step-title">Enter Your Employee ID</h2>
            
            <div class="id-display">
                @if (string.IsNullOrEmpty(employeeId))
                {
                    <span class="placeholder">- - - - -</span>
                }
                else
                {
                    <span class="employee-id">@employeeId</span>
                }
            </div>

            <div class="keypad">
                @for (int i = 1; i <= 9; i++)
                {
                    var digit = i.ToString();
                    <button class="key-btn" @onclick="@(() => AddDigit(digit))">@digit</button>
                }
                <button class="key-btn clear-btn" @onclick="ClearInput">
                    <span class="delete-label">⌫ Delete</span>
                </button>
                <button class="key-btn" @onclick="@(() => AddDigit("0"))">0</button>
                <button class="key-btn next-btn" @onclick="GoToCamera" disabled="@(employeeId.Length < 4)">
                    Next →
                </button>
            </div>

            @if (!string.IsNullOrEmpty(statusMessage))
            {
                <div class="status-message @statusClass">@statusMessage</div>
            }
                </div>
            }
            else if (currentStep == CheckInStep.TakePhoto)
            {
                <!-- Step 2: Take Photo -->
                <div class="camera-fullscreen">
            @if (!string.IsNullOrEmpty(cameraError))
            {
                <div class="error-panel">
                    <h2>⚠️ Camera Error</h2>
                    <p>@cameraError</p>
                    <button class="action-btn" @onclick="RetryCamera">Retry Camera</button>
                    <button class="action-btn secondary" @onclick="GoBackToID">← Back to ID Entry</button>
                </div>
            }
            else if (!string.IsNullOrEmpty(capturedPhoto))
            {
                <!-- Photo Preview -->
                <div class="photo-review">
                    <h2>Review Your Photo - @(isCheckIn ? "Check-In" : "Check-Out")</h2>
                    <img src="@capturedPhoto" alt="Your photo" class="captured-photo" />
                    <div class="photo-actions">
                        <button class="action-btn secondary" @onclick="RetakePhoto">
                            <span class="retake-icon">↻</span> Retake Photo
                        </button>
                        <button class="action-btn primary" @onclick="ConfirmCheckIn">
                            <span class="confirm-icon">✓</span> Confirm & @(isCheckIn ? "Check In" : "Check Out")
                        </button>
                    </div>
                </div>
            }
            else
            {
                <!-- Live Camera View -->
                <div class="camera-view">
                    <h2 class="camera-title">Take Your Photo for @(isCheckIn ? "Check-In" : "Check-Out")</h2>
                    <div class="video-container">
                        <video id="cameraFeed" autoplay playsinline muted></video>
                        <canvas id="photoCanvas" style="display: none;"></canvas>
                    </div>
                    <div class="camera-actions">
                        <button class="action-btn secondary" @onclick="GoBackToID">← Back to ID Entry</button>
                        <button class="action-btn capture" @onclick="TakePhoto">
                            <span class="shutter-icon"></span>
                            <span>Capture Photo</span>
                        </button>
                    </div>
                </div>
                }
            </div>
            }
            else if (currentStep == CheckInStep.Success)
            {
                <!-- Step 3: Success -->
                <div class="success-screen">
            <div class="success-icon">✓</div>
            <h2>@(isCheckIn ? "Check-In Successful!" : "Check-Out Successful!")</h2>
            <p>Employee ID: <strong>@employeeId</strong></p>
            <p class="timestamp">@checkInTimestamp.ToString("h:mm:ss tt")</p>
            <p style="color: #6b3a22; margin-top: 1rem;">@successMessage</p>
                    <button class="action-btn" @onclick="Reset">
                        <span style="font-size: 1.5rem; margin-right: 0.5rem;">✓</span> Complete
                    </button>
                </div>
            }
        </div>
    </div>
</div>
}

@code {
    private enum CheckInStep { EnterID, TakePhoto, Success }
    
    [Parameter]
    public int? BranchId { get; set; }
    
    // Security and Branch Selection
    private string securityPin = string.Empty;
    private string pinError = string.Empty;
    private List<Branch>? branches;
    
    // Check-in variables
    private CheckInStep currentStep = CheckInStep.EnterID;
    private string branchName = "";
    private string currentTime = "";
    private Timer? timer;
    private string employeeId = string.Empty;
    private string statusMessage = string.Empty;
    private string statusClass = string.Empty;
    private string capturedPhoto = string.Empty;
    private string cameraError = string.Empty;
    private string qrCodeDataUri = string.Empty;
    private bool isCheckIn = true;
    private DateTime checkInTimestamp = DateTime.Now;
    private string successMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        // Initialize app state from localStorage
        await AppState.InitializeAsync();
        
        // If BranchId is in URL, load that branch
        if (BranchId.HasValue && AppState.IsAuthenticated)
        {
            var branch = await BranchService.GetBranchByIdAsync(BranchId.Value);
            if (branch != null)
            {
                AppState.SelectedBranch = branch;
            }
        }
        
        // Load branches when showing branch selection screen
        if (AppState.IsAuthenticated && AppState.SelectedBranch == null)
        {
            await LoadBranches();
        }

        // Update branch name and initialize if a branch is already selected
        if (AppState.SelectedBranch != null)
        {
            branchName = AppState.SelectedBranch.Name;
            InitializeQRCode();
            UpdateClock();
            
            if (timer == null)
            {
                timer = new Timer(async _ => 
                {
                    UpdateClock();
                    await InvokeAsync(StateHasChanged);
                }, null, TimeSpan.Zero, TimeSpan.FromSeconds(1));
            }
        }
    }
    
    private async Task LoadBranches()
    {
        try
        {
            branches = await BranchService.GetBranchesAsync();
        }
        catch (Exception)
        {
            branches = new List<Branch>();
        }
    }
    
    // PIN Entry Methods
    private void AddPinDigit(string digit)
    {
        if (securityPin.Length < 6)
        {
            securityPin += digit;
            pinError = string.Empty;
        }
    }
    
    private void ClearPin()
    {
        if (securityPin.Length > 0)
        {
            securityPin = securityPin.Substring(0, securityPin.Length - 1);
        }
        pinError = string.Empty;
    }
    
    private async Task ValidatePin()
    {
        if (SecurityService.ValidatePin(securityPin))
        {
            AppState.IsAuthenticated = true;
            await LoadBranches();
            securityPin = string.Empty;
            pinError = string.Empty;
        }
        else
        {
            pinError = "Invalid PIN. Please try again.";
            securityPin = string.Empty;
        }
    }
    
    private async Task LogoutAsync()
    {
        // Reset all state
        await AppState.ResetAsync();
        
        // Reset component state
        employeeId = string.Empty;
        capturedPhoto = string.Empty;
        currentStep = CheckInStep.EnterID;
        statusMessage = string.Empty;
        branchName = string.Empty;
        qrCodeDataUri = string.Empty;
        
        // Stop timer
        timer?.Dispose();
        timer = null;
        
        // Navigate back to root to clear branch ID from URL
        Navigation.NavigateTo("/", forceLoad: true);
    }
    
    // Branch Selection Methods
    private void SelectBranch(Branch branch)
    {
        // Navigate to URL with branch ID
        Navigation.NavigateTo($"/{branch.Id}");
        
        AppState.SelectedBranch = branch;
        branchName = branch.Name;
        
        // Initialize QR code for the selected branch
        InitializeQRCode();
        
        // Start the clock timer
        UpdateClock();
        timer = new Timer(async _ => 
        {
            UpdateClock();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.Zero, TimeSpan.FromSeconds(1));
        
        StateHasChanged();
    }
    
    private void InitializeQRCode()
    {
        string checkInUrl = "https://www.northendcoffee.com/checkin";
        
        using (var qrGenerator = new QRCodeGenerator())
        {
            var qrCodeData = qrGenerator.CreateQrCode(checkInUrl, QRCodeGenerator.ECCLevel.Q);
            var qrCode = new PngByteQRCode(qrCodeData);
            var qrCodeBytes = qrCode.GetGraphic(20);
            qrCodeDataUri = $"data:image/png;base64,{Convert.ToBase64String(qrCodeBytes)}";
        }
    }
    
    private void UpdateClock()
    {
        currentTime = DateTime.Now.ToString("h:mm:ss tt");
    }
    
    private void AddDigit(string digit)
    {
        if (employeeId.Length < 10)
        {
            employeeId += digit;
            statusMessage = string.Empty;
        }
    }
    
    private void ClearInput()
    {
        if (employeeId.Length > 0)
        {
            employeeId = employeeId.Substring(0, employeeId.Length - 1);
        }
        statusMessage = string.Empty;
    }
    
    private async Task GoToCamera()
    {
        if (employeeId.Length >= 4)
        {
            // Validate employee ID first
            if (!CheckInService.ValidateEmployeeId(employeeId))
            {
                statusMessage = $"Employee ID {employeeId} not found in the system.";
                statusClass = "error";
                StateHasChanged();
                return;
            }
            
            // Check employee status to determine if this will be check-in or check-out
            var status = await CheckInService.GetEmployeeStatusAsync(employeeId);
            isCheckIn = !status.IsCheckedIn; // If not checked in, next action is check-in
            
            currentStep = CheckInStep.TakePhoto;
            cameraError = string.Empty;
            capturedPhoto = string.Empty;
            statusMessage = string.Empty;
            StateHasChanged();
            
            // Start camera after short delay to ensure DOM is ready
            await Task.Delay(300);
            await StartCamera();
        }
    }
    
    private async Task StartCamera()
    {
        try
        {
            var error = await JSRuntime.InvokeAsync<string>("initCamera");
            if (!string.IsNullOrEmpty(error))
            {
                cameraError = error;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            cameraError = $"Failed to start camera: {ex.Message}";
            StateHasChanged();
        }
    }
    
    private async Task TakePhoto()
    {
        try
        {
            capturedPhoto = await JSRuntime.InvokeAsync<string>("takePhoto");
            if (string.IsNullOrEmpty(capturedPhoto))
            {
                cameraError = "Failed to capture photo. Please try again.";
            }
            StateHasChanged();
        }
        catch (Exception ex)
        {
            cameraError = $"Capture error: {ex.Message}";
            StateHasChanged();
        }
    }
    
    private async Task RetakePhoto()
    {
        capturedPhoto = string.Empty;
        cameraError = string.Empty;
        StateHasChanged();
        await Task.Delay(100);
        await StartCamera();
    }
    
    private async Task RetryCamera()
    {
        cameraError = string.Empty;
        StateHasChanged();
        await Task.Delay(100);
        await StartCamera();
    }
    
    private async Task GoBackToID()
    {
        await JSRuntime.InvokeVoidAsync("stopCamera");
        currentStep = CheckInStep.EnterID;
        capturedPhoto = string.Empty;
        cameraError = string.Empty;
        StateHasChanged();
    }
    
    private async Task ConfirmCheckIn()
    {
        await JSRuntime.InvokeVoidAsync("stopCamera");
        
        // Call the check-in service
        var result = await CheckInService.ProcessCheckInAsync(employeeId, capturedPhoto);
        
        if (result.Success)
        {
            isCheckIn = result.IsCheckIn;
            checkInTimestamp = result.Timestamp;
            successMessage = result.Message;
            currentStep = CheckInStep.Success;
            StateHasChanged();
            
            // Auto-reset after 3 seconds
            await Task.Delay(3000);
            Reset();
        }
        else
        {
            // Show error message
            cameraError = result.ErrorMessage ?? "An error occurred during check-in.";
            StateHasChanged();
        }
    }
    
    private void Reset()
    {
        currentStep = CheckInStep.EnterID;
        employeeId = string.Empty;
        capturedPhoto = string.Empty;
        cameraError = string.Empty;
        statusMessage = string.Empty;
        StateHasChanged();
    }
    
    public void Dispose()
    {
        timer?.Dispose();
    }
}
